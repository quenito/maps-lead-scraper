{
  "manifest_version": 3,
  "name": "Maps Lead Scraper",
  "version": "3.0.1",
  "description": "Extract business leads and emails from Google Maps and Bing Maps search results",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://www.bing.com/maps/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.bing.com/maps*"],
      "js": ["content/bing-content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
